{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "build non quantized db to db_not_quantized folder",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "--db_path",
                "db_not_quantized"
            ]
        },
